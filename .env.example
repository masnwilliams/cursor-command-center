# Cursor Cloud Agent API key (from cursor.com/settings)
NEXT_PUBLIC_CURSOR_API_KEY=

# GitHub personal access token (fine-grained or classic)
NEXT_PUBLIC_GITHUB_TOKEN=

# Hypeship JWT (HS256 signed with HYPESHIP_JWT_SECRET)
NEXT_PUBLIC_HYPESHIP_JWT=

# Hypeship API URL override (defaults to production URL)
NEXT_PUBLIC_HYPESHIP_API_URL=

# Hypeship API keys (per-environment, used as fallback when JWT is not set)
NEXT_PUBLIC_HYPESHIP_PROD_API_KEY=
NEXT_PUBLIC_HYPESHIP_STAGING_API_KEY=
